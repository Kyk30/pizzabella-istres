# === CONFIGURATION PIZZA BELLA ===

# Mot de passe pour accéder au panel admin (/admin)
# Changez cette valeur avec un mot de passe sécurisé !
ADMIN_PASSWORD=pizzabella2024

# Clé secrète pour signer les tokens d'authentification
# Générez une chaîne aléatoire (ex: openssl rand -hex 32)
ADMIN_SECRET=changez-moi-avec-une-chaine-aleatoire-longue

# Token Vercel Blob (pour le stockage des images et du contenu en production)
# Obtenez-le dans: Vercel Dashboard > Votre projet > Storage > Blob > Token
# En développement local, les fichiers sont stockés sur le disque
BLOB_READ_WRITE_TOKEN=
